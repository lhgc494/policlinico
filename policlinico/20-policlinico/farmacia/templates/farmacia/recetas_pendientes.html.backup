{% extends 'base.html' %}

{% block title %}{{ titulo }}{% endblock %}

{% block content %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-prescription-bottle-medical"></i> {{ titulo }}</h2>
    </div>

    <!-- Filtros -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <!-- DNI -->
                <div class="col-md-3">
                    <label for="dni" class="form-label">DNI Paciente:</label>
                    <input type="text" 
                           class="form-control" 
                           id="dni" 
                           name="dni" 
                           value="{{ dni }}"
                           placeholder="Buscar por DNI">
                </div>
                
                <!-- Médico -->
                <div class="col-md-3">
                    <label for="doctor" class="form-label">Médico:</label>
                    <select class="form-select" id="doctor" name="doctor">
                        <option value="">Todos los médicos</option>
                        {% for doctor in doctores %}
                        <option value="{{ doctor.id }}" 
                                {% if doctor_id|add:"0" == doctor.id %}selected{% endif %}>
                            Dr. {{ doctor.nombres }} {{ doctor.apellidos }}
                        </option>
                        {% endfor %}
                    </select>
                </div>
                
                <!-- Fecha -->
                <div class="col-md-3">
                    <label for="fecha" class="form-label">Fecha:</label>
                    <select class="form-select" id="fecha" name="fecha">
                        <option value="">Todas las fechas</option>
                        <option value="hoy" {% if fecha_filtro == 'hoy' %}selected{% endif %}>Hoy</option>
                        <option value="semana" {% if fecha_filtro == 'semana' %}selected{% endif %}>Esta semana</option>
                        <option value="mes" {% if fecha_filtro == 'mes' %}selected{% endif %}>Este mes</option>
                    </select>
                </div>
                
                <!-- Estado -->
                <div class="col-md-3">
                    <label for="estado" class="form-label">Estado:</label>
                    <select class="form-select" id="estado" name="estado">
                        <option value="pendientes" {% if estado_filtro == 'pendientes' %}selected{% endif %}>Solo pendientes</option>
                        <option value="todas" {% if estado_filtro == 'todas' %}selected{% endif %}>Todas las recetas</option>
                    </select>
                </div>
                
                <!-- Botones -->
                <div class="col-12">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-search"></i> Filtrar
                    </button>
                    <a href="{% url 'recetas_pendientes' %}" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Limpiar
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Tabla de resultados -->
    {% if consultas %}
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th># Consulta</th>
                            <th>Paciente</th>
                            <th>DNI</th>
                            <th>Médico</th>
                            <th>Fecha</th>
                            <th>Total Recetas</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for consulta in consultas %}
                        <tr>
                            <td><strong>#{{ consulta.id }}</strong></td>
                            <td><strong>{{ consulta.paciente.nombres }} {{ consulta.paciente.apellidos }}</strong></td>
                            <td>{{ consulta.paciente.dni }}</td>
                            <td>
                                {% if consulta.doctor %}
                                    Dr. {{ consulta.doctor.nombres }} {{ consulta.doctor.apellidos }}
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td>{{ consulta.fecha|date:"d/m/Y H:i" }}</td>
                            <td>
                                <span class="badge bg-info">{{ consulta.total_recetas }}</span>
                            </td>
				<!-- En recetas_pendientes.html, busca la columna de acciones -->
<td>
    {% if consulta.total_recetas > 0 %}
    <div class="btn-group btn-group-sm" role="group">
        <!-- ENLACE DIRECTO en lugar de modal -->
        <a href="{% url 'detalle_recetas' consulta.id %}" 
           class="btn btn-success">
            <i class="fas fa-cash-register"></i> Atender
        </a>
        <button class="btn btn-danger btn-cancelar" 
                data-consulta-id="{{ consulta.id }}"
                data-paciente="{{ consulta.paciente.nombres }} {{ consulta.paciente.apellidos }}">
            <i class="fas fa-times"></i> Cancelar
        </button>
    </div>
    {% else %}
    <span class="text-muted">Sin recetas</span>
    {% endif %}
</td>
			</tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    {% else %}
    <div class="alert alert-info">
        <i class="fas fa-info-circle me-2"></i>
        No se encontraron consultas con los filtros aplicados.
    </div>
    {% endif %}
</div>

<!-- Modal para atención -->
<div class="modal fade" id="atencionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Atender Recetas - Consulta #<span id="modalConsultaId"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalBody">
                <!-- Cargado por AJAX -->
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Botones de atender
    document.querySelectorAll('.btn-atender').forEach(button => {
        button.addEventListener('click', function() {
            const consultaId = this.dataset.consultaId;
            
            // Cargar detalle de recetas via AJAX
            fetch(`/farmacia/detalle-recetas/${consultaId}/`)
                .then(response => response.text())
                .then(html => {
                    document.getElementById('modalBody').innerHTML = html;
                    document.getElementById('modalConsultaId').textContent = consultaId;
                    
                    // Mostrar modal
                    const modal = new bootstrap.Modal(document.getElementById('atencionModal'));
                    modal.show();
                })
                .catch(error => {
                    alert('Error al cargar las recetas: ' + error);
                });
        });
    });
    
    // Botones de cancelar
    document.querySelectorAll('.btn-cancelar').forEach(button => {
        button.addEventListener('click', function() {
            const consultaId = this.dataset.consultaId;
            const paciente = this.dataset.paciente;
            
            if (confirm(`¿Está seguro de cancelar TODAS las recetas de ${paciente}?\n\nEsta acción no se puede deshacer y la consulta desaparecerá de esta lista.`)) {
                fetch(`/farmacia/cancelar-recetas/${consultaId}/`, {
                    method: 'POST',
                    headers: {
                        'X-CSRFToken': '{{ csrf_token }}',
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        action: 'cancelar'
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Recargar la página para actualizar la lista
                        location.reload();
                    } else {
                        alert('Error: ' + data.message);
                    }
                })
                .catch(error => {
                    alert('Error en la solicitud: ' + error);
                });
            }
        });
    });
});
</script>
{% endblock %}
