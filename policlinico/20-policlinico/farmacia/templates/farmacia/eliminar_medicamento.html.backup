{% extends 'base.html' %}
{% load static %}

{% block title %}Desactivar Medicamento{% endblock %}

{% block extra_css %}
<style>
    .confirmation-box {
        border-left: 5px solid #dc3545;
        padding: 20px;
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }
    .warning-icon {
        font-size: 4rem;
        color: #dc3545;
    }
</style>
{% endblock %}

{% block content %}
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-danger text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">
                            <i class="fas fa-exclamation-triangle me-2"></i>Desactivar Medicamento
                        </h4>
                        <a href="{% url 'detalle_medicamento' medicamento.id %}" class="btn btn-light btn-sm">
                            <i class="fas fa-arrow-left me-1"></i> Volver
                        </a>
                    </div>
                </div>
                
                <div class="card-body">
                    <div class="confirmation-box">
                        <div class="text-center mb-4">
                            <div class="warning-icon">
                                <i class="fas fa-skull-crossbones"></i>
                            </div>
                            <h3 class="text-danger">¡PRECAUCIÓN!</h3>
                            <p class="lead">Está a punto de desactivar un medicamento del inventario</p>
                        </div>
                        
                        <!-- Información del medicamento -->
                        <div class="card mb-4">
                            <div class="card-body">
                                <h5 class="card-title">Medicamento a desactivar:</h5>
                                <div class="row">
                                    <div class="col-md-6">
                                        <p class="mb-1"><strong>Código:</strong></p>
                                        <p class="h5">{{ medicamento.codigo }}</p>
                                    </div>
                                    <div class="col-md-6">
                                        <p class="mb-1"><strong>Nombre comercial:</strong></p>
                                        <p class="h5 text-primary">{{ medicamento.nombre_comercial }}</p>
                                    </div>
                                    <div class="col-md-6">
                                        <p class="mb-1"><strong>Principio activo:</strong></p>
                                        <p>{{ medicamento.principio_activo }}</p>
                                    </div>
                                    <div class="col-md-6">
                                        <p class="mb-1"><strong>Concentración:</strong></p>
                                        <p>{{ medicamento.concentracion }}</p>
                                    </div>
                                    <div class="col-md-6">
                                        <p class="mb-1"><strong>Stock actual:</strong></p>
                                        <p class="h4 {% if medicamento.bajo_stock %}text-warning{% else %}text-success{% endif %}">
                                            {{ medicamento.stock_actual }} unidades
                                        </p>
                                    </div>
                                    <div class="col-md-6">
                                        <p class="mb-1"><strong>Valor en inventario:</strong></p>
                                        <p class="h4 text-success">S/ {{ medicamento.valor_inventario }}</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Consecuencias -->
                        <div class="alert alert-warning" role="alert">
                            <h5 class="alert-heading">
                                <i class="fas fa-exclamation-circle me-2"></i>¿Qué significa desactivar?
                            </h5>
                            <ul class="mb-0">
                                <li>El medicamento ya no aparecerá en las listas activas</li>
                                <li>No podrá ser seleccionado para nuevas recetas</li>
                                <li>Los registros existentes se mantendrán para historial</li>
                                <li>El stock permanecerá registrado pero no disponible</li>
                                <li>Podrás reactivarlo posteriormente si es necesario</li>
                            </ul>
                        </div>
                        
                        <!-- Razón de desactivación (opcional) -->
                        <div class="mb-4">
                            <label for="razon" class="form-label">
                                <strong>¿Por qué desactivas este medicamento? (opcional)</strong>
                            </label>
                            <textarea class="form-control" id="razon" name="razon" rows="3" 
                                      placeholder="Ej: Producto discontinuado, cambio de proveedor, etc."></textarea>
                        </div>
                        
                        <!-- Confirmación final -->
                        <div class="alert alert-danger" role="alert">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="confirmar" required>
                                <label class="form-check-label" for="confirmar">
                                    <strong>Comprendo las consecuencias y deseo continuar</strong>
                                </label>
                            </div>
                        </div>
                        
                        <!-- Formulario de confirmación -->
                        <form method="post" onsubmit="return confirmarDesactivacion()">
                            {% csrf_token %}
                            <div class="d-flex justify-content-between">
                                <a href="{% url 'detalle_medicamento' medicamento.id %}" class="btn btn-secondary btn-lg">
                                    <i class="fas fa-times me-2"></i> Cancelar
                                </a>
                                <button type="submit" class="btn btn-danger btn-lg" id="btnConfirmar" disabled>
                                    <i class="fas fa-trash me-2"></i> Sí, Desactivar Medicamento
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const checkbox = document.getElementById('confirmar');
    const btnConfirmar = document.getElementById('btnConfirmar');
    
    // Habilitar/deshabilitar botón según checkbox
    checkbox.addEventListener('change', function() {
        btnConfirmar.disabled = !this.checked;
    });
    
    // Confirmación adicional antes de enviar
    window.confirmarDesactivacion = function() {
        if (!checkbox.checked) {
            alert('Debes confirmar que comprendes las consecuencias.');
            return false;
        }
        
        return confirm('¿ESTÁS ABSOLUTAMENTE SEGURO de desactivar este medicamento?\n\nEsta acción afectará a recetas futuras y reportes.');
    };
});
</script>
{% endblock %}
