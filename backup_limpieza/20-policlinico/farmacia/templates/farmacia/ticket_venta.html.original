<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ titulo }} - Policlínico</title>
    <style>
        body {
            font-family: 'Courier New', monospace;
            font-size: 12px;
            width: 80mm;
            margin: 0;
            padding: 5mm;
        }
        .header {
            text-align: center;
            border-bottom: 1px dashed #000;
            padding-bottom: 5px;
            margin-bottom: 5px;
        }
        .header h1 {
            font-size: 16px;
            margin: 0;
        }
        .header h2 {
            font-size: 14px;
            margin: 0;
            font-weight: normal;
        }
        .info {
            margin: 5px 0;
        }
        .info table {
            width: 100%;
        }
        .info td {
            padding: 2px 0;
        }
        .info .label {
            font-weight: bold;
        }
        .items {
            margin: 10px 0;
        }
        .items table {
            width: 100%;
            border-collapse: collapse;
        }
        .items th {
            border-bottom: 1px solid #000;
            padding: 3px 0;
            text-align: left;
        }
        .items td {
            padding: 2px 0;
            border-bottom: 1px dotted #ccc;
        }
        .total {
            margin-top: 10px;
            padding-top: 5px;
            border-top: 2px solid #000;
        }
        .total table {
            width: 100%;
        }
        .total td {
            padding: 3px 0;
        }
        .total .amount {
            text-align: right;
            font-weight: bold;
        }
        .footer {
            margin-top: 15px;
            text-align: center;
            font-size: 10px;
            border-top: 1px dashed #000;
            padding-top: 5px;
        }
        @media print {
            body {
                width: 80mm;
            }
            .no-print {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>POLICLÍNICO</h1>
        <h2>Sistema de Farmacia</h2>
        <div>VENTA DIRECTA</div>
    </div>
    
    <div class="info">
        <table>
            <tr>
                <td class="label">Ticket #:</td>
                <td>{{ venta.id }}</td>
            </tr>
            <tr>
                <td class="label">Fecha:</td>
                <td>{{ venta.fecha_hora|date:"d/m/Y H:i" }}</td>
            </tr>
            <tr>
                <td class="label">Vendedor:</td>
                <td>{{ venta.usuario.get_full_name|default:venta.usuario.username }}</td>
            </tr>
            <tr>
                <td class="label">Pago:</td>
                <td>{{ venta.get_metodo_pago_display }}</td>
            </tr>
        </table>
    </div>
    
    <div class="items">
        <table>
            <thead>
                <tr>
                    <th>Producto</th>
                    <th style="text-align: center;">Cant</th>
                    <th style="text-align: right;">P.U.</th>
                    <th style="text-align: right;">Total</th>
                </tr>
            </thead>
            <tbody>
                {% for detalle in detalles %}
                <tr>
                    <td>{{ detalle.medicamento.nombre_comercial }}</td>
                    <td style="text-align: center;">{{ detalle.cantidad }}</td>
                    <td style="text-align: right;">S/ {{ detalle.precio_unitario|floatformat:2 }}</td>
                    <td style="text-align: right;">S/ {{ detalle.subtotal|floatformat:2 }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    
    <div class="total">
        <table>
            <tr>
                <td>Subtotal:</td>
                <td class="amount">S/ {{ venta.total|add:venta.descuento|floatformat:2 }}</td>
            </tr>
            <tr>
                <td>Descuento:</td>
                <td class="amount">S/ {{ venta.descuento|floatformat:2 }}</td>
            </tr>
            <tr>
                <td style="font-weight: bold;">TOTAL:</td>
                <td class="amount" style="font-size: 14px;">S/ {{ venta.total|floatformat:2 }}</td>
            </tr>
        </table>
    </div>
    
    {% if venta.observaciones %}
    <div class="observaciones">
        <strong>Observaciones:</strong><br>
        {{ venta.observaciones }}
    </div>
    {% endif %}
    
    <div class="footer">
        <div>*** GRACIAS POR SU COMPRA ***</div>
        <div>Tel: (01) 123-4567</div>
        <div>www.policlinico.com</div>
        <div class="no-print">
            <br>
            <button onclick="window.print()">Imprimir Ticket</button>
            <button onclick="window.close()">Cerrar</button>
        </div>
    </div>
    
    <script>
        // Auto-imprimir al cargar
        window.onload = function() {
            setTimeout(function() {
                window.print();
                // Cerrar después de imprimir (opcional)
                // setTimeout(function() { window.close(); }, 1000);
            }, 500);
        }
    </script>
</body>
</html>
