{% extends 'base.html' %}

{% block title %}Atender Recetas - Consulta #{{ consulta.id }}{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <!-- Encabezado -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h3 class="mb-3">
                <i class="fas fa-prescription-bottle-medical text-primary me-2"></i>
                Atender Recetas - Consulta #{{ consulta.id }}
            </h3>

            <div class="card bg-light">
                <div class="card-body py-3">
                    <div class="row">
                        <div class="col-md-6">
                            <p class="mb-2">
                                <i class="fas fa-user me-2"></i>
                                <strong>Paciente:</strong> {{ consulta.paciente.nombres }} {{ consulta.paciente.apellidos }}
                            </p>
                            <p class="mb-2">
                                <i class="fas fa-id-card me-2"></i>
                                <strong>DNI:</strong> {{ consulta.paciente.dni }}
                            </p>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-2">
                                <i class="fas fa-user-md me-2"></i>
                                <strong>Médico:</strong> Dr. {{ consulta.doctor.nombres }} {{ consulta.doctor.apellidos }}
                            </p>
                            <p class="mb-0">
                                <i class="fas fa-calendar me-2"></i>
                                <strong>Fecha consulta:</strong> {{ consulta.fecha|date:"d/m/Y H:i" }}
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-primary text-white">
                <div class="card-body text-center">
                    <h4 class="mb-0">TOTAL</h4>
                    <h2 class="mb-0 mt-2" id="totalGeneral">S/ 0.00</h2>
                    <small class="opacity-75">Subtotal de medicamentos seleccionados</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Formulario de atención -->
    <form id="formAtencionRecetas">
        {% csrf_token %}

        <div class="card">
            <div class="card-header bg-white">
                <h5 class="mb-0">
                    <i class="fas fa-list me-2"></i>
                    Medicamentos Recetados
                    <span class="badge bg-info ms-2">{{ recetas|length }}</span>
                </h5>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th width="50" class="text-center">
                                    <input type="checkbox" id="selectAll" checked>
                                </th>
                                <th>Medicamento</th>
                                <th>Indicaciones Médicas</th>
                                <th class="text-center">Stock</th>
                                <th class="text-center">Recetado</th>
                                <th width="150">Cantidad a Vender</th>
                                <th class="text-center">Precio Unit.</th>
                                <th class="text-center">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for receta in recetas %}
                            <tr class="{% if not receta.stock_suficiente %}table-danger{% endif %}"
                                data-precio="{{ receta.precio_unitario|default:0 }}">
                                <td class="text-center">
                                    <input type="checkbox"
                                           class="medicamento-check form-check-input"
                                           id="check_{{ receta.id }}"
                                           name="recetas[]"
                                           value="{{ receta.id }}"
                                           {% if receta.maximo_vender > 0 %}checked{% endif %}
                                           {% if receta.maximo_vender == 0 %}disabled{% endif %}>
                                </td>
                                <td>
                                    <strong>{{ receta.medicamento }}</strong><br>
                                    <small class="text-muted">{{ receta.dosis }}</small>
                                </td>
                                <td>
                                    <small>
                                        <strong>{{ receta.frecuencia }}</strong> por {{ receta.duracion }}<br>
                                        {% if receta.indicaciones %}
                                        <em>"{{ receta.indicaciones }}"</em>
                                        {% endif %}
                                    </small>
                                </td>
                                <td class="text-center">
                                    {% if receta.stock_suficiente %}
                                    <span class="badge bg-success">{{ receta.stock_disponible }}</span>
                                    {% else %}
                                    <span class="badge bg-danger">{{ receta.stock_disponible }}</span>
                                    <small class="d-block text-danger">Falta stock</small>
                                    {% endif %}
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-secondary">{{ receta.cantidad }}</span>
                                </td>
                                <td>
                                    <input type="number"
                                           class="form-control form-control-sm cantidad-input"
                                           id="cant_{{ receta.id }}"
                                           name="cantidad_{{ receta.id }}"
                                           value="{{ receta.cantidad }}"
                                           min="1"
                                           max="{{ receta.maximo_vender|default:receta.cantidad }}"
                                           data-default="{{ receta.cantidad }}"
                                           {% if receta.maximo_vender == 0 %}disabled{% endif %}>
                                    <small class="text-muted">
                                        Máx: {{ receta.maximo_vender|default:receta.cantidad }}
                                        | Stock: {{ receta.stock_disponible|default:0 }}
                                    </small>
                                </td>
                                <td class="text-center">
                                    <span class="precio-unitario">S/ {{ receta.precio_unitario|floatformat:2|default:"0.00" }}</span>
                                </td>
                                <td class="text-center">
                                    <span class="subtotal fw-bold text-success" id="subtotal_{{ receta.id }}">S/ 0.00</span>
                                </td>
                            </tr>
                            {% empty %}
                            <tr>
                                <td colspan="8" class="text-center py-4">
                                    <div class="text-muted">
                                        <i class="fas fa-info-circle fa-2x mb-3"></i>
                                        <p>No hay recetas registradas para esta consulta</p>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card-footer bg-white">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <div class="alert alert-info mb-0">
                            <h6 class="mb-2"><i class="fas fa-info-circle me-2"></i>Instrucciones:</h6>
                            <ul class="mb-0 small">
                                <li>Desmarque medicamentos que <strong>NO</strong> se entregarán</li>
                                <li>Ajuste la cantidad según stock disponible</li>
                                <li>Fila roja = stock insuficiente</li>
                                <li>El subtotal y total se calculan automáticamente</li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-md-6 text-end">
                        <button type="button"
                                class="btn btn-primary btn-lg px-5"
                                id="btnContinuarPago"
                                disabled>
                            <i class="fas fa-arrow-right me-2"></i> Continuar al Pago
                        </button>
                        <a href="{% url 'recetas_pendientes' %}" class="btn btn-secondary ms-2">
                            <i class="fas fa-times me-2"></i> Cancelar
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
{% endblock %}

{% block extra_js %}
<script>
// Prevenir comportamientos no deseados
document.addEventListener('DOMContentLoaded', function() {
    console.log('Inicializando módulo de atención de recetas...');

    // ========== PREVENIR ENTER Y SUBMIT ==========
    // Prevenir ENTER en inputs
    document.querySelectorAll('.cantidad-input').forEach(input => {
        input.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                console.log('ENTER prevenido en input', this.id);
                // Opcional: mover foco al siguiente input
                const inputs = document.querySelectorAll('.cantidad-input');
                const currentIndex = Array.from(inputs).indexOf(this);
                if (currentIndex < inputs.length - 1) {
                    inputs[currentIndex + 1].focus();
                }
                return false;
            }
        });
    });

    // Prevenir submit accidental
    const form = document.getElementById('formAtencionRecetas');
    if (form && form.tagName === 'FORM') {
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            console.log('Submit del formulario prevenido');
            alert('Por favor use el botón "Continuar al Pago"');
            return false;
        });
    }

    // ========== INICIALIZAR CÁLCULOS ==========
    calcularTodosSubtotales();
    
    // ========== CONFIGURAR EVENTOS ==========
    // 1. Configurar evento para "Seleccionar todos"
    const selectAllCheckbox = document.getElementById('selectAll');
    if (selectAllCheckbox) {
        selectAllCheckbox.addEventListener('change', function() {
            const checkboxes = document.querySelectorAll('.medicamento-check:not(:disabled)');
            checkboxes.forEach(checkbox => {
                checkbox.checked = this.checked;
                toggleCantidadInput(checkbox);
            });
            calcularTodosSubtotales();
            verificarBotonPago();
        });
    }
    
    // 2. Configurar eventos para checkboxes individuales
    document.querySelectorAll('.medicamento-check').forEach(checkbox => {
        checkbox.addEventListener('change', function() {
            const recetaId = this.value;
            toggleCantidadInput(this);
            calcularSubtotal(recetaId);
            verificarBotonPago();
        });
        
        // Inicializar estado
        toggleCantidadInput(checkbox);
    });
    
    // 3. Configurar eventos para inputs de cantidad
    document.querySelectorAll('.cantidad-input').forEach(input => {
        input.addEventListener('input', function() {
            const recetaId = this.id.replace('cant_', '');
            calcularSubtotal(recetaId);
            verificarBotonPago();
        });
        
        // También con change (por si usan las flechas)
        input.addEventListener('change', function() {
            const recetaId = this.id.replace('cant_', '');
            calcularSubtotal(recetaId);
            verificarBotonPago();
        });
    });
    
    // 4. Configurar botón "Continuar al Pago"
    const btnContinuar = document.getElementById('btnContinuarPago');
    if (btnContinuar) {
        btnContinuar.addEventListener('click', function() {
            procesarPago();
        });
    }
    
    // 5. Verificar estado inicial del botón
    verificarBotonPago();
    
    console.log('Módulo inicializado correctamente');
});

// ============================================
// FUNCIONES PRINCIPALES
// ============================================

function toggleCantidadInput(checkbox) {
    const recetaId = checkbox.value;
    const cantidadInput = document.getElementById(`cant_${recetaId}`);
    if (cantidadInput) {
        cantidadInput.disabled = !checkbox.checked;
        if (!checkbox.checked) {
            cantidadInput.value = 0;
        } else if (parseInt(cantidadInput.value) === 0) {
            // Si se activa y está en 0, poner el valor por defecto
            cantidadInput.value = cantidadInput.getAttribute('data-default') || 1;
        }
    }
}

function calcularSubtotal(recetaId) {
    // Obtener elementos
    const checkbox = document.getElementById(`check_${recetaId}`);
    const cantidadInput = document.getElementById(`cant_${recetaId}`);

    if (!checkbox || !cantidadInput) {
        console.error(`No se encontraron elementos para receta ${recetaId}`);
        return;
    }

    // Obtener datos
    const fila = checkbox.closest('tr');
    const precio = parseFloat(fila.getAttribute('data-precio')) || 0;
    const cantidad = checkbox.checked ? parseInt(cantidadInput.value) || 0 : 0;

    // Calcular subtotal
    const subtotal = precio * cantidad;

    // Actualizar en pantalla
    const subtotalElement = document.getElementById(`subtotal_${recetaId}`);
    if (subtotalElement) {
        subtotalElement.textContent = `S/ ${subtotal.toFixed(2)}`;
    }

    // Actualizar total
    calcularTotal();
}

function calcularTodosSubtotales() {
    document.querySelectorAll('.medicamento-check').forEach(checkbox => {
        if (checkbox.checked && !checkbox.disabled) {
            const recetaId = checkbox.value;
            calcularSubtotal(recetaId);
        }
    });
}

function calcularTotal() {
    let total = 0;

    // Sumar todos los subtotales
    document.querySelectorAll('.subtotal').forEach(element => {
        const texto = element.textContent.replace('S/ ', '').trim();
        const valor = parseFloat(texto);
        if (!isNaN(valor)) {
            total += valor;
        }
    });

    // Actualizar en pantalla
    const totalElement = document.getElementById('totalGeneral');
    if (totalElement) {
        totalElement.textContent = `S/ ${total.toFixed(2)}`;
    }

    return total;
}

function obtenerDatosAtencion() {
    const items = [];

    document.querySelectorAll('.medicamento-check:checked').forEach(checkbox => {
        const recetaId = checkbox.value;
        const cantidadInput = document.getElementById(`cant_${recetaId}`);
        const fila = checkbox.closest('tr');
        const precio = parseFloat(fila.getAttribute('data-precio')) || 0;
        const cantidad = parseInt(cantidadInput.value) || 0;

        if (cantidad > 0) {
            items.push({
                receta_id: recetaId,
                cantidad: cantidad,
                precio: precio,
                subtotal: precio * cantidad
            });
        }
    });

    return { items: items };
}

function verificarBotonPago() {
    const btn = document.getElementById('btnContinuarPago');
    if (!btn) return;

    const tieneItems = document.querySelectorAll('.medicamento-check:checked').length > 0;
    const total = calcularTotal();

    btn.disabled = !(tieneItems && total > 0);
}

function procesarPago() {
    const datos = obtenerDatosAtencion();

    if (datos.items.length === 0) {
        alert('Debe seleccionar al menos un medicamento');
        return;
    }

    const total = calcularTotal();

    // Crear formulario temporal
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = `/farmacia/procesar-pago/{{ consulta.id }}/`;

    // CSRF token
    const csrfInput = document.createElement('input');
    csrfInput.type = 'hidden';
    csrfInput.name = 'csrfmiddlewaretoken';
    csrfInput.value = '{{ csrf_token }}';
    form.appendChild(csrfInput);

    // Total
    const totalInput = document.createElement('input');
    totalInput.type = 'hidden';
    totalInput.name = 'total';
    totalInput.value = total;
    form.appendChild(totalInput);

    // Items
    datos.items.forEach((item, index) => {
        const recetaInput = document.createElement('input');
        recetaInput.type = 'hidden';
        recetaInput.name = `recetas[${index}][receta_id]`;
        recetaInput.value = item.receta_id;
        form.appendChild(recetaInput);

        const cantidadInput = document.createElement('input');
        cantidadInput.type = 'hidden';
        cantidadInput.name = `recetas[${index}][cantidad]`;
        cantidadInput.value = item.cantidad;
        form.appendChild(cantidadInput);

        const precioInput = document.createElement('input');
        precioInput.type = 'hidden';
        precioInput.name = `recetas[${index}][precio]`;
        precioInput.value = item.precio;
        form.appendChild(precioInput);
    });

    // Enviar
    document.body.appendChild(form);
    form.submit();
}

// Función de depuración
function verificarEstado() {
    console.log('=== VERIFICANDO ESTADO ===');

    const checkboxes = document.querySelectorAll('.medicamento-check:checked');
    console.log('Checkboxes marcados:', checkboxes.length);

    let total = 0;
    checkboxes.forEach(checkbox => {
        const recetaId = checkbox.value;
        const cantidadInput = document.getElementById(`cant_${recetaId}`);
        const cantidad = parseInt(cantidadInput.value) || 0;
        console.log(`Receta ${recetaId}: cantidad=${cantidad}`);

        if (cantidad > 0) {
            const fila = checkbox.closest('tr');
            const precio = parseFloat(fila.getAttribute('data-precio')) || 0;
            total += precio * cantidad;
        }
    });

    console.log('Total calculado:', total);
    console.log('Botón habilitado?', total > 0);

    return total > 0;
}
</script>
{% endblock %}
