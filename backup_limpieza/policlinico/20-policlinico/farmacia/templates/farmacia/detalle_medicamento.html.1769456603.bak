{% extends 'base.html' %}
{% load static %}

{% block title %}Detalle: {{ medicamento.nombre_comercial }}{% endblock %}

{% block extra_css %}
<style>
    .field-label {
        font-weight: 600;
        color: #495057;
        margin-bottom: 0.25rem;
    }
    .field-value {
        color: #212529;
        margin-bottom: 0.5rem;
    }
    .info-card {
        border-left: 4px solid #007bff;
    }
    .stock-card {
        border-left: 4px solid #28a745;
    }
    .lot-card {
        border-left: 4px solid #fd7e14;
    }
    .classification-card {
        border-left: 4px solid #6f42c1;
    }
    .control-card {
        border-left: 4px solid #dc3545;
    }
    .status-badge {
        font-size: 0.75em;
        padding: 0.25em 0.6em;
    }
    .alert-banner {
        border-radius: 0.375rem;
        padding: 1rem;
        margin-bottom: 1rem;
    }
</style>
{% endblock %}

{% block content %}
<div class="container-fluid">
    <!-- Encabezado con estado -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow border-0">
                <div class="card-header d-flex justify-content-between align-items-center bg-primary text-white">
                    <div>
                        <h4 class="mb-0">
                            <i class="fas fa-pills me-2"></i>{{ medicamento.nombre_comercial }}
                            {% if not medicamento.activo %}
                            <span class="badge bg-secondary ms-2">INACTIVO</span>
                            {% endif %}
                        </h4>
                        <small class="opacity-75">{{ medicamento.principio_activo }}</small>
                    </div>
                    <div class="btn-group">
                        <a href="{% url 'farmacia:editar_medicamento' medicamento.id %}" class="btn btn-warning text-white">
                            <i class="fas fa-edit me-1"></i> Editar
                        </a>
                        <a href="{% url 'farmacia:ajustar_inventario' medicamento.id %}" class="btn btn-info text-white">
                            <i class="fas fa-exchange-alt me-1"></i> Ajustar Stock
                        </a>
                        <a href="{% url 'farmacia:lista_medicamentos' %}" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i> Volver
                        </a>
                    </div>
                </div>
                
                <!-- Alertas de estado -->
                <div class="card-body p-3">
                    <div class="row">
                        {% if medicamento.stock_actual <= 0 %}
                        <div class="col-md-6">
                            <div class="alert alert-danger alert-banner mb-0">
                                <i class="fas fa-times-circle me-2"></i>
                                <strong>SIN STOCK:</strong> 
                                No hay unidades disponibles
                            </div>
                        </div>
                        {% elif medicamento.stock_actual < medicamento.stock_minimo %}
                        <div class="col-md-6">
                            <div class="alert alert-warning alert-banner mb-0">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                <strong>STOCK BAJO:</strong> 
                                {{ medicamento.stock_actual }} unidades (Mínimo: {{ medicamento.stock_minimo }})
                            </div>
                        </div>
                        {% endif %}
                        
                        {% if medicamento.proximo_vencer %}
                        <div class="col-md-6">
                            <div class="alert alert-danger alert-banner mb-0">
                                <i class="fas fa-calendar-times me-2"></i>
                                <strong>PRÓXIMO A VENCER:</strong> 
                                {{ medicamento.fecha_vencimiento|date:"d/m/Y" }}
                            </div>
                        </div>
                        {% endif %}
                        
                        {% if medicamento.vencido %}
                        <div class="col-md-6">
                            <div class="alert alert-dark alert-banner mb-0">
                                <i class="fas fa-skull-crossbones me-2"></i>
                                <strong>VENCIDO</strong> - No debe ser vendido
                            </div>
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Contenido principal -->
    <div class="row">
        <!-- Columna izquierda -->
        <div class="col-lg-8">
            <div class="row">
                <!-- Información Básica -->
                <div class="col-md-6 mb-4">
                    <div class="card shadow h-100 info-card">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <i class="fas fa-info-circle text-primary me-2"></i>
                                Información Básica
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <div class="field-label">Código</div>
                                <div class="field-value">
                                    <strong>{{ medicamento.codigo|default:"Sin código" }}</strong>
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <div class="field-label">Nombre comercial</div>
                                <div class="field-value">{{ medicamento.nombre_comercial }}</div>
                            </div>
                            
                            {% if medicamento.nombre_generico %}
                            <div class="mb-3">
                                <div class="field-label">Nombre genérico</div>
                                <div class="field-value">{{ medicamento.nombre_generico }}</div>
                            </div>
                            {% endif %}
                            
                            <div class="mb-3">
                                <div class="field-label">Principio activo</div>
                                <div class="field-value">{{ medicamento.principio_activo }}</div>
                            </div>
                            
                            {% if medicamento.concentracion %}
                            <div class="mb-3">
                                <div class="field-label">Concentración</div>
                                <div class="field-value">{{ medicamento.concentracion }}</div>
                            </div>
                            {% endif %}
                            
                            {% if medicamento.forma_farmaceutica %}
                            <div class="mb-3">
                                <div class="field-label">Forma farmacéutica</div>
                                <div class="field-value">{{ medicamento.get_forma_farmaceutica_display }}</div>
                            </div>
                            {% endif %}
                            
                            {% if medicamento.condiciones_almacenamiento %}
                            <div class="mb-3">
                                <div class="field-label">Condiciones almacenamiento</div>
                                <div class="field-value">{{ medicamento.condiciones_almacenamiento }}</div>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <!-- Clasificación -->
                <div class="col-md-6 mb-4">
                    <div class="card shadow h-100 classification-card">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <i class="fas fa-tags text-purple me-2"></i>
                                Clasificación
                            </h5>
                        </div>
                        <div class="card-body">
                            {% if medicamento.categoria %}
                            <div class="mb-3">
                                <div class="field-label">Categoría</div>
                                <div class="field-value">
                                    <span class="badge bg-info">
                                        {{ medicamento.get_categoria_display }}
                                    </span>
                                </div>
                            </div>
                            {% endif %}
                            
                            {% if medicamento.presentacion %}
                            <div class="mb-3">
                                <div class="field-label">Presentación</div>
                                <div class="field-value">{{ medicamento.presentacion.nombre }}</div>
                            </div>
                            {% endif %}
                            
                            {% if medicamento.proveedor %}
                            <div class="mb-3">
                                <div class="field-label">Proveedor</div>
                                <div class="field-value">
                                    {{ medicamento.proveedor.nombre }}
                                    {% if medicamento.proveedor.telefono %}
                                    <br><small class="text-muted">
                                        <i class="fas fa-phone"></i> {{ medicamento.proveedor.telefono }}
                                    </small>
                                    {% endif %}
                                </div>
                            </div>
                            {% endif %}
                            
                            {% if medicamento.fabricante %}
                            <div class="mb-3">
                                <div class="field-label">Fabricante</div>
                                <div class="field-value">{{ medicamento.fabricante }}</div>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <!-- Stock y Precios -->
                <div class="col-md-6 mb-4">
                    <div class="card shadow h-100 stock-card">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <i class="fas fa-boxes text-success me-2"></i>
                                Stock y Precios
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-6 mb-3">
                                    <div class="field-label">Stock actual</div>
                                    <div class="field-value h4 
                                        {% if medicamento.stock_actual <= 0 %}text-danger
                                        {% elif medicamento.stock_actual < medicamento.stock_minimo %}text-warning
                                        {% else %}text-success{% endif %}">
                                        {{ medicamento.stock_actual|default:"0" }}
                                    </div>
                                </div>
                                
                                <div class="col-6 mb-3">
                                    <div class="field-label">Stock mínimo</div>
                                    <div class="field-value">{{ medicamento.stock_minimo|default:"0" }}</div>
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <div class="field-label">Stock máximo</div>
                                <div class="field-value">{{ medicamento.stock_maximo|default:"0" }}</div>
                            </div>
                            
                            <hr>
                            
                            <div class="row">
                                <div class="col-6 mb-3">
                                    <div class="field-label">Precio compra</div>
                                    <div class="field-value">
                                        <strong>S/ {{ medicamento.precio_compra|default:"0.00" }}</strong>
                                    </div>
                                </div>
                                
                                <div class="col-6 mb-3">
                                    <div class="field-label">Precio venta</div>
                                    <div class="field-value text-success">
                                        <strong>S/ {{ medicamento.precio_venta|default:"0.00" }}</strong>
                                    </div>
                                </div>
                            </div>
                            
                            {% if medicamento.precio_venta_mayorista %}
                            <div class="mb-3">
                                <div class="field-label">Precio venta mayorista</div>
                                <div class="field-value text-info">
                                    S/ {{ medicamento.precio_venta_mayorista|default:"0.00" }}
                                </div>
                            </div>
                            {% endif %}
                            
                            <!-- Cálculo de valores -->
                            <hr>
                            <div class="row">
                                <div class="col-6 mb-3">
                                    <div class="field-label">Valor inventario</div>
                                    <div class="field-value">
                                        <strong>
                                            S/ {% if medicamento.valor_inventario %}
                                                {{ medicamento.valor_inventario|floatformat:2 }}
                                            {% else %}
                                                0.00
                                            {% endif %}
                                        </strong>
                                    </div>
                                </div>
                                
                                <div class="col-6 mb-3">
                                    <div class="field-label">Margen</div>
                                    <div class="field-value">
                                        {% if medicamento.precio_compra and medicamento.precio_venta and medicamento.precio_compra > 0 %}
                                            {% with pc=medicamento.precio_compra|floatformat:2 pv=medicamento.precio_venta|floatformat:2 %}
                                                {% widthratio pv pc 100 as porcentaje %}
                                                <span class="text-success">{{ porcentaje|add:"-100"|floatformat:2 }}%</span>
                                            {% endwith %}
                                        {% else %}
                                            0.00%
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Información de Lote -->
                <div class="col-md-6 mb-4">
                    <div class="card shadow h-100 lot-card">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <i class="fas fa-box-open text-warning me-2"></i>
                                Información de Lote
                            </h5>
                        </div>
                        <div class="card-body">
                            {% if medicamento.lote %}
                            <div class="mb-3">
                                <div class="field-label">Lote</div>
                                <div class="field-value">
                                    <span class="badge bg-secondary">{{ medicamento.lote }}</span>
                                </div>
                            </div>
                            {% endif %}
                            
                            {% if medicamento.registro_sanitario %}
                            <div class="mb-3">
                                <div class="field-label">Registro sanitario</div>
                                <div class="field-value">{{ medicamento.registro_sanitario }}</div>
                            </div>
                            {% endif %}
                            
                            <div class="mb-3">
                                <div class="field-label">Fecha vencimiento</div>
                                <div class="field-value">
                                    {% if medicamento.fecha_vencimiento %}
                                    {{ medicamento.fecha_vencimiento|date:"d/m/Y" }}
                                    <span class="badge 
                                        {% if medicamento.vencido %}bg-danger
                                        {% elif medicamento.proximo_vencer %}bg-warning
                                        {% else %}bg-success{% endif %} ms-2 status-badge">
                                        {% if medicamento.vencido %}VENCIDO
                                        {% elif medicamento.proximo_vencer %}PRÓXIMO
                                        {% else %}VIGENTE{% endif %}
                                    </span>
                                    
                                    {% if medicamento.dias_vencimiento %}
                                    <br>
                                    <small class="text-muted">
                                        {% if medicamento.dias_vencimiento > 0 %}
                                            <i class="fas fa-clock"></i> Vence en {{ medicamento.dias_vencimiento }} días
                                        {% else %}
                                            <i class="fas fa-exclamation-triangle"></i>
                                            Vencido hace {{ medicamento.dias_vencimiento|stringformat:"+d"|slice:"1:" }} días
                                        {% endif %}
                                    </small>
                                    {% endif %}
                                    
                                    {% else %}
                                    <span class="text-muted">No asignada</span>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Columna derecha -->
        <div class="col-lg-4">
            <!-- Información Adicional -->
            <div class="card shadow mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="fas fa-notes-medical text-info me-2"></i>
                        Información Adicional
                    </h5>
                </div>
                <div class="card-body">
                    {% if medicamento.descripcion %}
                    <div class="mb-3">
                        <div class="field-label">Descripción</div>
                        <div class="field-value small">{{ medicamento.descripcion|linebreaks }}</div>
                    </div>
                    {% endif %}
                    
                    {% if medicamento.indicaciones %}
                    <div class="mb-3">
                        <div class="field-label">Indicaciones</div>
                        <div class="field-value small">{{ medicamento.indicaciones|linebreaks }}</div>
                    </div>
                    {% endif %}
                    
                    {% if medicamento.contraindicaciones %}
                    <div class="mb-3">
                        <div class="field-label">Contraindicaciones</div>
                        <div class="field-value small">{{ medicamento.contraindicaciones|linebreaks }}</div>
                    </div>
                    {% endif %}
                    
                    {% if not medicamento.descripcion and not medicamento.indicaciones and not medicamento.contraindicaciones %}
                    <div class="text-center text-muted py-3">
                        <i class="fas fa-sticky-note fa-2x mb-2"></i>
                        <p>No hay información adicional</p>
                    </div>
                    {% endif %}
                </div>
            </div>

            <!-- Control y Estado -->
            <div class="card shadow control-card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="fas fa-clipboard-check text-danger me-2"></i>
                        Control y Estado
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-6 mb-3">
                            <div class="field-label">Requiere receta</div>
                            <div class="field-value">
                                {% if medicamento.requiere_receta %}
                                <span class="badge bg-danger">
                                    <i class="fas fa-file-prescription me-1"></i> SÍ
                                </span>
                                {% else %}
                                <span class="badge bg-success">NO</span>
                                {% endif %}
                            </div>
                        </div>
                        
                        <div class="col-6 mb-3">
                            <div class="field-label">Controlado</div>
                            <div class="field-value">
                                {% if medicamento.controlado %}
                                <span class="badge bg-danger">
                                    <i class="fas fa-exclamation-triangle me-1"></i> SÍ
                                </span>
                                {% else %}
                                <span class="badge bg-success">NO</span>
                                {% endif %}
                            </div>
                        </div>
                        
                        <div class="col-6 mb-3">
                            <div class="field-label">Refrigerado</div>
                            <div class="field-value">
                                {% if medicamento.refrigerado %}
                                <span class="badge bg-info">
                                    <i class="fas fa-snowflake me-1"></i> SÍ
                                </span>
                                {% else %}
                                <span class="badge bg-secondary">NO</span>
                                {% endif %}
                            </div>
                        </div>
                        
                        <div class="col-6 mb-3">
                            <div class="field-label">Activo</div>
                            <div class="field-value">
                                {% if medicamento.activo %}
                                <span class="badge bg-success">ACTIVO</span>
                                {% else %}
                                <span class="badge bg-secondary">INACTIVO</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    
                    <!-- Metadatos -->
                    <div class="mt-4 pt-3 border-top">
                        <div class="row small text-muted">
                            <div class="col-6">
                                <div class="field-label">Creado</div>
                                <div>
                                    {% if medicamento.fecha_creacion %}
                                        {{ medicamento.fecha_creacion|date:"d/m/Y" }}
                                    {% else %}
                                        -
                                    {% endif %}
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="field-label">Modificado</div>
                                <div>
                                    {% if medicamento.fecha_modificacion %}
                                        {{ medicamento.fecha_modificacion|date:"d/m/Y H:i" }}
                                    {% else %}
                                        -
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Historial de movimientos -->
    {% if movimientos %}
    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card shadow">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="fas fa-history me-2"></i>
                        Historial de Movimientos Recientes
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Fecha</th>
                                    <th>Tipo</th>
                                    <th>Cantidad</th>
                                    <th>Usuario</th>
                                    <th>Referencia</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for movimiento in movimientos %}
                                <tr>
                                    <td>{{ movimiento.fecha|date:"d/m/Y H:i" }}</td>
                                    <td>
                                        <span class="badge 
                                            {% if movimiento.tipo == 'ENTRADA' %}bg-success
                                            {% else %}bg-danger{% endif %}">
                                            {{ movimiento.get_tipo_display }}
                                        </span>
                                    </td>
                                    <td>{{ movimiento.cantidad }}</td>
                                    <td>{{ movimiento.usuario.username }}</td>
                                    <td>{{ movimiento.referencia|truncatechars:30 }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}

{% block extra_js %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Resaltar stock crítico
    const stockElement = document.querySelector('.field-value.h4.text-danger');
    if (stockElement && stockElement.textContent.trim() === '0') {
        stockElement.innerHTML = '<i class="fas fa-exclamation-circle me-1"></i>' + stockElement.innerHTML;
    }
});
</script>
{% endblock %}
