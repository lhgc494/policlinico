{% extends 'base.html' %}

{% block title %}{{ titulo }}{% endblock %}

{% block content %}
<div class="container py-4">
    <div class="row">
        <div class="col-md-8">
            <!-- Encabezado -->
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-credit-card me-2"></i>
                        Pago de Recetas - Consulta #{{ consulta.id }}
                    </h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p class="mb-2">
                                <i class="fas fa-user me-2"></i>
                                <strong>Paciente:</strong> {{ consulta.paciente.nombres }} {{ consulta.paciente.apellidos }}
                            </p>
                            <p class="mb-2">
                                <i class="fas fa-id-card me-2"></i>
                                <strong>DNI:</strong> {{ consulta.paciente.dni }}
                            </p>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-2">
                                <i class="fas fa-user-md me-2"></i>
                                <strong>Médico:</strong> Dr. {{ consulta.doctor.nombres }} {{ consulta.doctor.apellidos }}
                            </p>
                            <p class="mb-0">
                                <i class="fas fa-calendar me-2"></i>
                                <strong>Fecha:</strong> {{ consulta.fecha|date:"d/m/Y H:i" }}
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Resumen de compra -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-shopping-cart me-2"></i>
                        Resumen de la Compra
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Medicamento</th>
                                    <th class="text-center">Cantidad</th>
                                    <th class="text-center">Precio Unit.</th>
                                    <th class="text-center">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in items %}
                                <tr>
                                    <td>
                                        <strong>{{ item.receta.medicamento }}</strong><br>
                                        <small class="text-muted">{{ item.receta.dosis }}</small>
                                    </td>
                                    <td class="text-center">{{ item.cantidad }}</td>
                                    <td class="text-center">S/ {{ item.precio|floatformat:2 }}</td>
                                    <td class="text-center">
                                        <strong class="text-success">S/ {{ item.subtotal|floatformat:2 }}</strong>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Panel de pago -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-calculator me-2"></i>
                        Total a Pagar
                    </h5>
                </div>
                <div class="card-body">
                    <!-- Subtotal -->
                    <div class="d-flex justify-content-between mb-2">
                        <span>Subtotal:</span>
                        <strong>S/ <span id="subtotalDisplay">{{ subtotal|floatformat:2 }}</span></strong>
                    </div>

                    <!-- Descuento -->
                    <div class="mb-3">
                        <label for="descuento" class="form-label">
                            <i class="fas fa-tag me-1"></i> Descuento Manual:
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">S/</span>
                            <input type="number" 
                                   class="form-control" 
                                   id="descuento" 
                                   name="descuento"
                                   min="0"
                                   max="{{ subtotal }}"
                                   step="0.01"
                                   value="0"
                                   placeholder="0.00">
                        </div>
                        <small class="text-muted">Ingrese monto fijo (no porcentaje)</small>
                    </div>

                    <!-- Forma de pago -->
                    <div class="mb-4">
                        <label class="form-label">
                            <i class="fas fa-money-bill-wave me-1"></i> Forma de Pago:
                        </label>
                        <div class="btn-group-vertical w-100" role="group">
                            <input type="radio" class="btn-check" name="metodo_pago" id="efectivo" value="EFECTIVO" checked>
                            <label class="btn btn-outline-primary text-start" for="efectivo">
                                <i class="fas fa-money-bill me-2"></i> Efectivo
                            </label>
                            
                            <input type="radio" class="btn-check" name="metodo_pago" id="yape" value="YAPE">
                            <label class="btn btn-outline-primary text-start" for="yape">
                                <i class="fas fa-mobile-alt me-2"></i> Yape
                            </label>
                            
                            <input type="radio" class="btn-check" name="metodo_pago" id="plin" value="PLIN">
                            <label class="btn btn-outline-primary text-start" for="plin">
                                <i class="fas fa-qrcode me-2"></i> Plin
                            </label>
                        </div>
                    </div>

                    <!-- Total final -->
                    <div class="border-top pt-3">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="mb-0">TOTAL:</h5>
                            <h3 class="mb-0 text-primary" id="totalFinal">S/ {{ total|floatformat:2 }}</h3>
                        </div>

                        <!-- Botones -->
                        <form method="post" action="{% url 'finalizar_pago' consulta.id %}" id="formPagoFinal">
                            {% csrf_token %}
                            <input type="hidden" name="total_final" id="totalFinalInput" value="{{ total }}">
                            <input type="hidden" name="descuento_aplicado" id="descuentoInput" value="0">
                            <input type="hidden" name="metodo_pago" id="metodoPagoInput" value="EFECTIVO">
                            
                            <!-- Campos para cada receta -->
                            {% for item in items %}
                            <input type="hidden" name="recetas[{{ forloop.counter0 }}][receta_id]" value="{{ item.receta.id }}">
                            <input type="hidden" name="recetas[{{ forloop.counter0 }}][cantidad]" value="{{ item.cantidad }}">
                            <input type="hidden" name="recetas[{{ forloop.counter0 }}][precio]" value="{{ item.precio }}">
                            {% endfor %}
                            
                            <button type="submit" class="btn btn-success btn-lg w-100 mb-2">
                                <i class="fas fa-check-circle me-2"></i> Confirmar Pago
                            </button>
                            <a href="{% url 'detalle_recetas' consulta.id %}" class="btn btn-secondary w-100">
                                <i class="fas fa-arrow-left me-2"></i> Modificar Recetas
                            </a>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const subtotal = parseFloat("{{ subtotal }}");
    const descuentoInput = document.getElementById('descuento');
    const totalFinal = document.getElementById('totalFinal');
    const totalFinalInput = document.getElementById('totalFinalInput');
    const descuentoInputHidden = document.getElementById('descuentoInput');
    
    // Formas de pago
    const metodoPagoInput = document.getElementById('metodoPagoInput');
    document.querySelectorAll('input[name="metodo_pago"]').forEach(radio => {
        radio.addEventListener('change', function() {
            metodoPagoInput.value = this.value;
        });
    });
    
    // Calcular total cuando cambia el descuento
    descuentoInput.addEventListener('input', function() {
        let descuento = parseFloat(this.value) || 0;
        
        // Validar que no sea mayor al subtotal
        if (descuento > subtotal) {
            descuento = subtotal;
            this.value = descuento.toFixed(2);
        }
        
        // Calcular total
        const total = subtotal - descuento;
        
        // Actualizar display
        totalFinal.textContent = `S/ ${total.toFixed(2)}`;
        totalFinalInput.value = total.toFixed(2);
        descuentoInputHidden.value = descuento.toFixed(2);
    });
});
</script>
{% endblock %}
