{% extends 'base.html' %}
{% load static %}

{% block title %}{{ titulo }}{% endblock %}

{% block extra_css %}
<style>
    .form-section {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 25px;
        border-left: 4px solid #0d6efd;
    }
    .form-section h5 {
        color: #0d6efd;
        border-bottom: 1px solid #dee2e6;
        padding-bottom: 10px;
        margin-bottom: 20px;
    }
    .required label:after {
        content: " *";
        color: #dc3545;
    }
    .alert-icon {
        font-size: 1.5rem;
        margin-right: 10px;
    }
</style>
{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-lg">
                <div class="card-header bg-primary text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h4 class="mb-0">
                                <i class="fas fa-edit me-2"></i>{{ titulo }}
                            </h4>
                            <small class="opacity-75">
                                Código: {{ medicamento.codigo }} |
                                Última actualización: {{ medicamento.fecha_actualizacion|date:"d/m/Y H:i" }}
                            </small>
                        </div>
                        <div>
                            <a href="{% url 'detalle_medicamento' medicamento.id %}" class="btn btn-light btn-sm">
                                <i class="fas fa-eye me-1"></i> Ver Detalle
                            </a>
                            <a href="{% url 'lista_medicamentos' %}" class="btn btn-light btn-sm ms-2">
                                <i class="fas fa-arrow-left me-1"></i> Volver
                            </a>
                        </div>
                    </div>
                </div>

                <div class="card-body">
                    <!-- Alertas de estado -->
                    {% if medicamento.vencido %}
                    <div class="alert alert-dark d-flex align-items-center mb-4" role="alert">
                        <i class="fas fa-skull-crossbones alert-icon"></i>
                        <div>
                            <strong>¡ATENCIÓN!</strong> Este medicamento está VENCIDO desde
                            {{ medicamento.fecha_vencimiento|date:"d/m/Y" }}
                        </div>
                    </div>
                    {% elif medicamento.proximo_vencer %}
                    <div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
                        <i class="fas fa-exclamation-triangle alert-icon"></i>
                        <div>
                            <strong>¡PRECAUCIÓN!</strong> Este medicamento vence en
                            {{ medicamento.dias_vencimiento }} días ({{ medicamento.fecha_vencimiento|date:"d/m/Y" }})
                        </div>
                    </div>
                    {% elif medicamento.bajo_stock %}
                    <div class="alert alert-info d-flex align-items-center mb-4" role="alert">
                        <i class="fas fa-box alert-icon"></i>
                        <div>
                            <strong>Stock bajo:</strong> Solo quedan {{ medicamento.stock_actual }} unidades
                            (mínimo recomendado: {{ medicamento.stock_minimo }})
                        </div>
                    </div>
                    {% endif %}

                    <!-- Formulario -->
                    <form method="post" novalidate>
                        {% csrf_token %}
                        
                        {% if form.errors %}
                        <div class="alert alert-danger">
                            <strong>Error:</strong> Por favor corrige los errores a continuación.
                            <ul class="mb-0 mt-2">
                                {% for field, errors in form.errors.items %}
                                    {% for error in errors %}
                                        <li>{{ field }}: {{ error }}</li>
                                    {% endfor %}
                                {% endfor %}
                            </ul>
                        </div>
                        {% endif %}
                        
                        <!-- Sección 1: Información Básica -->
                        <div class="form-section">
                            <h5><i class="fas fa-info-circle me-2"></i>Información Básica</h5>
                            <div class="row">
                                <div class="col-md-6 mb-3 required">
                                    {{ form.codigo.label_tag }}
                                    {{ form.codigo }}
                                    {% if form.codigo.help_text %}
                                    <small class="form-text text-muted">{{ form.codigo.help_text }}</small>
                                    {% endif %}
                                </div>
                                
                                <div class="col-md-6 mb-3 required">
                                    {{ form.nombre_comercial.label_tag }}
                                    {{ form.nombre_comercial }}
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3 required">
                                    {{ form.principio_activo.label_tag }}
                                    {{ form.principio_activo }}
                                </div>
                                
                                <div class="col-md-6 mb-3 required">
                                    {{ form.concentracion.label_tag }}
                                    {{ form.concentracion }}
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    {{ form.categoria.label_tag }}
                                    {{ form.categoria }}
                                </div>
                                
                                <div class="col-md-6 mb-3">
                                    {{ form.presentacion.label_tag }}
                                    {{ form.presentacion }}
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-12 mb-3">
                                    {{ form.descripcion.label_tag }}
                                    {{ form.descripcion }}
                                    {% if form.descripcion.help_text %}
                                    <small class="form-text text-muted">{{ form.descripcion.help_text }}</small>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                        
                        <!-- Sección 2: Stock y Precios -->
                        <div class="form-section">
                            <h5><i class="fas fa-boxes me-2"></i>Stock y Precios</h5>
                            <div class="row">
                                <div class="col-md-3 mb-3 required">
                                    {{ form.stock_actual.label_tag }}
                                    {{ form.stock_actual }}
                                    {% if form.stock_actual.help_text %}
                                    <small class="form-text text-muted">{{ form.stock_actual.help_text }}</small>
                                    {% endif %}
                                </div>
                                
                                <div class="col-md-3 mb-3 required">
                                    {{ form.stock_minimo.label_tag }}
                                    {{ form.stock_minimo }}
                                    {% if form.stock_minimo.help_text %}
                                    <small class="form-text text-muted">{{ form.stock_minimo.help_text }}</small>
                                    {% endif %}
                                </div>
                                
                                <div class="col-md-3 mb-3 required">
                                    {{ form.precio_compra.label_tag }}
                                    {{ form.precio_compra }}
                                    {% if form.precio_compra.help_text %}
                                    <small class="form-text text-muted">{{ form.precio_compra.help_text }}</small>
                                    {% endif %}
                                </div>
                                
                                <div class="col-md-3 mb-3 required">
                                    {{ form.precio_venta.label_tag }}
                                    {{ form.precio_venta }}
                                    {% if form.precio_venta.help_text %}
                                    <small class="form-text text-muted">{{ form.precio_venta.help_text }}</small>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                        
                        <!-- Sección 3: Fechas y Estado -->
                        <div class="form-section">
                            <h5><i class="fas fa-calendar-alt me-2"></i>Fechas y Estado</h5>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    {{ form.fecha_vencimiento.label_tag }}
                                    {{ form.fecha_vencimiento }}
                                    {% if form.fecha_vencimiento.help_text %}
                                    <small class="form-text text-muted">{{ form.fecha_vencimiento.help_text }}</small>
                                    {% endif %}
                                </div>
                                
                                <div class="col-md-6 mb-3">
                                    {{ form.lote.label_tag }}
                                    {{ form.lote }}
                                    {% if form.lote.help_text %}
                                    <small class="form-text text-muted">{{ form.lote.help_text }}</small>
                                    {% endif %}
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    {{ form.proveedor.label_tag }}
                                    {{ form.proveedor }}
                                </div>
                                
                                <div class="col-md-6 mb-3">
                                    <div class="form-check mt-4">
                                        {{ form.activo }}
                                        <label class="form-check-label" for="{{ form.activo.id_for_label }}">
                                            {{ form.activo.label }}
                                        </label>
                                        {% if form.activo.help_text %}
                                        <small class="form-text text-muted d-block">{{ form.activo.help_text }}</small>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Botones -->
                        <div class="row mt-4">
                            <div class="col-12">
                                <div class="d-flex justify-content-between">
                                    <div>
                                        <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#eliminarModal">
                                            <i class="fas fa-trash me-1"></i> Desactivar
                                        </button>
                                    </div>
                                    <div>
                                        <a href="{% url 'lista_medicamentos' %}" class="btn btn-secondary me-2">
                                            <i class="fas fa-times me-1"></i> Cancelar
                                        </a>
                                        <button type="submit" class="btn btn-success">
                                            <i class="fas fa-save me-1"></i> Guardar Cambios
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Información adicional -->
                <div class="card-footer bg-light">
                    <div class="row">
                        <div class="col-md-3 text-center">
                            <small class="text-muted d-block">Valor en inventario</small>
                            <div class="h5 text-success">S/ {{ medicamento.valor_inventario|default:"0.00" }}</div>
                        </div>
                        <div class="col-md-3 text-center">
                            <small class="text-muted d-block">Valor de venta</small>
                            <div class="h5 text-primary">S/ {{ medicamento.valor_venta_inventario|default:"0.00" }}</div>
                        </div>
                        <div class="col-md-3 text-center">
                            <small class="text-muted d-block">Días hasta vencimiento</small>
                            <div class="h5 {% if medicamento.vencido %}text-danger{% elif medicamento.proximo_vencer %}text-warning{% else %}text-success{% endif %}">
                                {{ medicamento.dias_vencimiento|default:"N/A" }}
                            </div>
                        </div>
                        <div class="col-md-3 text-center">
                            <small class="text-muted d-block">Margen actual</small>
                            <div class="h5 text-info">{{ medicamento.margen_ganancia|floatformat:2|default:"0.00" }}%</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal para confirmar eliminación -->
<div class="modal fade" id="eliminarModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="fas fa-exclamation-triangle me-2"></i>Confirmar Desactivación
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Estás seguro de que deseas desactivar este medicamento?</p>
                <div class="alert alert-warning">
                    <i class="fas fa-info-circle me-2"></i>
                    El medicamento se ocultará del sistema pero no se eliminará permanentemente.
                </div>
                <p><strong>Medicamento:</strong> {{ medicamento.nombre_comercial }}</p>
                <p><strong>Código:</strong> {{ medicamento.codigo }}</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i> Cancelar
                </button>
                <a href="{% url 'eliminar_medicamento' medicamento.id %}" class="btn btn-danger">
                    <i class="fas fa-trash me-1"></i> Sí, Desactivar
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Formatear precios automáticamente
    const precioCompra = document.getElementById('id_precio_compra');
    const precioVenta = document.getElementById('id_precio_venta');
    
    if (precioCompra) {
        precioCompra.addEventListener('blur', function(e) {
            let value = parseFloat(e.target.value);
            if (!isNaN(value)) {
                e.target.value = value.toFixed(2);
            }
        });
    }
    
    if (precioVenta) {
        precioVenta.addEventListener('blur', function(e) {
            let value = parseFloat(e.target.value);
            if (!isNaN(value)) {
                e.target.value = value.toFixed(2);
            }
        });
    }
    
    // Validación en tiempo real del precio de venta
    if (precioCompra && precioVenta) {
        function validarPrecios() {
            const compra = parseFloat(precioCompra.value) || 0;
            const venta = parseFloat(precioVenta.value) || 0;
            
            if (venta < compra) {
                precioVenta.classList.add('is-invalid');
                const feedback = precioVenta.nextElementSibling || document.createElement('div');
                if (!feedback.classList.contains('invalid-feedback')) {
                    feedback.className = 'invalid-feedback';
                    feedback.textContent = `El precio de venta no puede ser menor al de compra (S/ ${compra.toFixed(2)})`;
                    precioVenta.parentNode.appendChild(feedback);
                }
                return false;
            } else {
                precioVenta.classList.remove('is-invalid');
                const feedback = precioVenta.nextElementSibling;
                if (feedback && feedback.classList.contains('invalid-feedback')) {
                    feedback.remove();
                }
                return true;
            }
        }
        
        precioCompra.addEventListener('blur', validarPrecios);
        precioVenta.addEventListener('blur', validarPrecios);
        precioVenta.addEventListener('input', validarPrecios);
    }
});
</script>
{% endblock %}
