@login_required
@never_cache
def crear_medicamento(request):
    """Crea un nuevo medicamento en el inventario"""
    if request.method == 'POST':
        form = MedicamentoForm(request.POST)
        if form.is_valid():
            try:
                medicamento = form.save(commit=False)
                # Calcular valor de inventario
                medicamento.valor_inventario = medicamento.stock_actual * medicamento.precio_compra
                medicamento.save()

                # Registrar movimiento inicial
                MovimientoInventario.objects.create(
                    medicamento=medicamento,
                    tipo='ENTRADA',
                    cantidad=medicamento.stock_actual,
                    usuario=request.user,
                    referencia=f'Creación de medicamento - Stock inicial',
                    precio_unitario=medicamento.precio_compra
                )

                messages.success(
                    request,
                    f'✅ Medicamento creado exitosamente: {medicamento.nombre_comercial}'
                )
                return redirect('farmacia:lista_medicamentos')
            except Exception as e:
                messages.error(
                    request,
                    f'❌ Error al crear medicamento: {str(e)}'
                )
        else:
            messages.error(
                request,
                '❌ Por favor corrige los errores en el formulario'
            )
    else:
        form = MedicamentoForm()

    context = {
        'form': form,
        'titulo': 'Registrar Nuevo Medicamento'
    }

    return render(request, 'farmacia/crear_medicamento.html', context)

