@login_required
@never_cache
def procesar_pago(request, consulta_id):
    """Procesa el pago de recetas seleccionadas"""
    from consultas.models import Consulta

    if request.method == 'POST':
        try:
            consulta = get_object_or_404(Consulta, id=consulta_id)
            total = float(request.POST.get('total', 0))

            # Obtener recetas seleccionadas
            items = []
            index = 0
            while True:
                receta_id = request.POST.get(f'recetas[{index}][receta_id]')
                if not receta_id:
                    break

                cantidad = int(request.POST.get(f'recetas[{index}][cantidad]', 0))
                precio = float(request.POST.get(f'recetas[{index}][precio]', 0))

                if cantidad > 0:
                    # Buscar la receta
                    receta = consulta.recetas.filter(id=receta_id).first()
                    if receta:
                        items.append({
                            'receta': receta,
                            'cantidad': cantidad,
                            'precio': precio,
                            'subtotal': precio * cantidad
                        })

                index += 1

            if not items:
                messages.error(request, 'No se seleccionaron medicamentos')
                return redirect('farmacia:detalle_recetas_consulta', consulta_id=consulta_id)

            context = {
                'consulta': consulta,
                'items': items,
                'subtotal': total,
                'descuento': 0,
                'total': total,
                'titulo': 'Pago de Recetas'
            }

            return render(request, 'farmacia/pago_recetas.html', context)

        except Exception as e:
            messages.error(request, f'Error al procesar pago: {str(e)}')
            return redirect('farmacia:recetas_pendientes')

    # Si no es POST, redirigir
    return redirect('farmacia:detalle_recetas_consulta', consulta_id=consulta_id)

@login_required
@never_cache
def finalizar_pago(request, tipo=None, id=None):
    """Finaliza el pago para consultas O ventas directas"""
    
    # Determinar tipo de pago
    if tipo == 'consulta':
        from consultas.models import Consulta

        if request.method == 'POST':
            try:
                consulta = get_object_or_404(Consulta, id=id)
                total_final = float(request.POST.get('total_final', 0))
                descuento = float(request.POST.get('descuento_aplicado', 0))
                metodo_pago = request.POST.get('metodo_pago', 'EFECTIVO')

                # Obtener recetas seleccionadas
                recetas_atendidas = []
                index = 0

                while True:
                    receta_id = request.POST.get(f'recetas[{index}][receta_id]')
                    if not receta_id:
                        break

                    cantidad = int(request.POST.get(f'recetas[{index}][cantidad]', 0))

                    if cantidad > 0:
                        # Buscar la receta
                        receta = consulta.recetas.filter(id=receta_id).first()
                        if receta:
                            # Verificar stock
                            try:
                                medicamento = Medicamento.objects.filter(
                                    nombre_comercial__icontains=receta.medicamento.split()[0]
                                ).first()

                                if medicamento and medicamento.stock_actual >= cantidad:
                                    # 1. Actualizar receta
                                    receta.cantidad_atendida = cantidad
                                    receta.estado = 'ATENDIDA'
                                    receta.usuario_atencion = request.user
                                    receta.fecha_atencion = timezone.now()
                                    receta.observaciones_farmacia = f'Pagado con {metodo_pago} - Descuento: S/ {descuento}'
                                    receta.save()

                                    # 2. Descontar stock
                                    medicamento.stock_actual -= cantidad
                                    medicamento.save()

                                    # 3. Crear venta
                                    venta = Venta.objects.create(
                                        total=total_final,
                                        descuento=descuento,
                                        metodo_pago=metodo_pago,
                                        observaciones=f'Venta desde receta - Consulta #{consulta.id}',
                                        usuario=request.user
                                    )

                                    # 4. Crear detalle de venta
                                    DetalleVenta.objects.create(
                                        venta=venta,
                                        medicamento=medicamento,
                                        cantidad=cantidad,
                                        precio_unitario=medicamento.precio_venta,
                                        subtotal=medicamento.precio_venta * cantidad
                                    )

                                    # 5. Registrar movimiento
                                    MovimientoInventario.objects.create(
                                        medicamento=medicamento,
                                        tipo='VENTA',
                                        cantidad=cantidad,
                                        usuario=request.user,
                                        referencia=f'Venta receta #{receta.id} - Consulta #{consulta.id}',
                                        precio_unitario=medicamento.precio_venta
                                    )

                                    recetas_atendidas.append({
                                        'receta': receta,
                                        'cantidad': cantidad,
                                        'medicamento': medicamento,
                                        'venta': venta
                                    })
                                else:
                                    messages.warning(
                                        request,
                                        f'Stock insuficiente para {receta.medicamento}'
                                    )
                            except Exception as e:
                                messages.warning(
                                    request,
                                    f'Error con {receta.medicamento}: {str(e)}'
                                )

                    index += 1

                if not recetas_atendidas:
                    messages.error(request, 'No se pudo procesar ninguna receta')
                    return redirect('farmacia:procesar_pago', consulta_id=id)

                # Usar el ticket de venta
                if recetas_atendidas and 'venta' in recetas_atendidas[0]:
                    return redirect('farmacia:ticket_venta', id=recetas_atendidas[0]['venta'].id)

                messages.success(
                    request,
                    f'✅ Pago procesado exitosamente. Total: S/ {total_final:.2f}'
                )
                return redirect('farmacia:recetas_pendientes')

            except Exception as e:
                messages.error(request, f'❌ Error al procesar pago: {str(e)}')
                return redirect('farmacia:recetas_pendientes')

        # Si no es POST, redirigir
        return redirect('farmacia:procesar_pago', consulta_id=id)

    elif tipo == 'venta_directa':
        # Lógica para venta directa - REDIRIGIR al ticket
        return redirect('farmacia:ticket_venta', id=id)

    else:
        # Tipo no válido
        messages.error(request, 'Tipo de pago no válido')
        return redirect('farmacia:venta_directa')
