@login_required
def procesar_venta_directa(request):
    """Procesa una venta directa"""
    if request.method == 'POST':
        try:
            with transaction.atomic():
                # Obtener datos del formulario
                medicamento_ids = request.POST.getlist('medicamento_ids')
                cantidades = request.POST.getlist('cantidades')
                metodo_pago = request.POST.get('metodo_pago', 'EFECTIVO')
                descuento_str = request.POST.get('descuento', '0')
                observaciones = request.POST.get('observaciones', '')

                # Validar que hay medicamentos
                if not medicamento_ids or len(medicamento_ids) == 0:
                    return JsonResponse({
                        'success': False,
                        'message': 'No hay medicamentos seleccionados'
                    }, status=400)

                # Convertir descuento a Decimal
                try:
                    descuento = Decimal(descuento_str)
                except:
                    descuento = Decimal('0')

                # Calcular total y validar stock
                total = Decimal('0')
                items_venta = []

                for i in range(len(medicamento_ids)):
                    try:
                        medicamento_id = int(medicamento_ids[i])
                        cantidad = int(cantidades[i])
                    except (ValueError, IndexError):
                        return JsonResponse({
                            'success': False,
                            'message': 'Datos de medicamentos inválidos'
                        }, status=400)

                    # Obtener medicamento
                    medicamento = get_object_or_404(Medicamento, id=medicamento_id)

                    # Validar stock
                    if cantidad > medicamento.stock_actual:
                        return JsonResponse({
                            'success': False,
                            'message': f'Stock insuficiente para {medicamento.nombre_comercial}. Disponible: {medicamento.stock_actual}'
                        }, status=400)

                    # Calcular subtotal
                    subtotal = medicamento.precio_venta * cantidad
                    total += subtotal

                    items_venta.append({
                        'medicamento': medicamento,
                        'cantidad': cantidad,
                        'precio': medicamento.precio_venta,
                        'subtotal': subtotal
                    })

                # Aplicar descuento (no puede ser mayor al total)
                if descuento > total:
                    descuento = total

                total_final = total - descuento
                if total_final < 0:
                    total_final = Decimal('0')

                # Crear la venta
                venta = Venta.objects.create(
                    total=total_final,
                    descuento=descuento,
                    metodo_pago=metodo_pago,
                    observaciones=observaciones,
                    usuario=request.user
                )

                # Crear detalles y actualizar stock
                for item in items_venta:
                    DetalleVenta.objects.create(
                        venta=venta,
                        medicamento=item['medicamento'],
                        cantidad=item['cantidad'],
                        precio_unitario=item['precio'],
                        subtotal=item['subtotal']
                    )

                    # Actualizar stock
                    item['medicamento'].stock_actual -= item['cantidad']
                    item['medicamento'].save()

                    # Registrar movimiento de inventario
                    MovimientoInventario.objects.create(
                        medicamento=item['medicamento'],
                        tipo='VENTA',
                        cantidad=item['cantidad'],
                        usuario=request.user,
                        referencia=f'Venta directa #{venta.id}',
                        precio_unitario=item['precio']
                    )

                return JsonResponse({
                    'success': True,
                    'venta_id': venta.id,
                    'message': 'Venta procesada exitosamente'
                })

        except Exception as e:
            import traceback
            error_detail = traceback.format_exc()
            print(f"Error en procesar_venta_directa: {str(e)}")
            print(f"Detalle: {error_detail}")

            return JsonResponse({
                'success': False,
                'message': f'Error al procesar la venta: {str(e)}'
            }, status=500)

    return JsonResponse({
        'success': False,
        'message': 'Método no permitido'
    }, status=405)

