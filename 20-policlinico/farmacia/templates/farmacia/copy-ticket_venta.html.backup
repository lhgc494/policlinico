{% extends 'base.html' %}
{% load custom_filters %}

{% block title %}{{ titulo }}{% endblock %}

{% block content %}
<div class="container py-4">
    <div class="card">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0">
                <i class="fas fa-check-circle me-2"></i>
                Pago Completado Exitosamente
            </h4>
        </div>

        <div class="card-body">
            <!-- Encabezado -->
            <div class="text-center mb-4">
                <h2>POLICLÍNICO</h2>
                <p class="mb-0">Ticket de Venta - Farmacia</p>
                <p class="text-muted">{{ fecha_pago|date:"d/m/Y H:i" }}</p>
            </div>

            <!-- Datos paciente -->
            <div class="row mb-4">
                <div class="col-md-6">
                    <p><strong>Paciente:</strong> {{ consulta.paciente.nombres }} {{ consulta.paciente.apellidos }}</p>
                    <p><strong>DNI:</strong> {{ consulta.paciente.dni }}</p>
                </div>
                <div class="col-md-6">
                    <p><strong>Consulta #:</strong> {{ consulta.id }}</p>
                    <p><strong>Atendió:</strong> {{ usuario.username }}</p>
                </div>
            </div>

            <!-- Detalle de venta -->
            <table class="table table-sm mb-4">
                <thead>
                    <tr>
                        <th>Medicamento</th>
                        <th class="text-center">Cant.</th>
                        <th class="text-end">Precio</th>
                        <th class="text-end">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in recetas_atendidas %}
                    <tr>
                        <td>{{ item.receta.medicamento }}</td>
                        <td class="text-center">{{ item.cantidad }}</td>
                        <td class="text-end">S/ {{ item.medicamento.precio_venta|floatformat:2 }}</td>
                        <td class="text-end">S/ {{ item.cantidad|multiply:item.medicamento.precio_venta|floatformat:2 }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>

            <!-- Totales -->
            <div class="row justify-content-end">
                <div class="col-md-6">
                    <table class="table table-sm">
                        <tr>
                            <td><strong>Subtotal:</strong></td>
                            <td class="text-end">S/ {{ total_final|add:descuento|floatformat:2 }}</td>
                        </tr>
                        {% if descuento > 0 %}
                        <tr>
                            <td><strong>Descuento:</strong></td>
                            <td class="text-end text-danger">- S/ {{ descuento|floatformat:2 }}</td>
                        </tr>
                        {% endif %}
                        <tr class="table-active">
                            <td><strong>TOTAL:</strong></td>
                            <td class="text-end"><strong>S/ {{ total_final|floatformat:2 }}</strong></td>
                        </tr>
                        <tr>
                            <td><strong>Forma de pago:</strong></td>
                            <td class="text-end">{{ metodo_pago }}</td>
                        </tr>
                    </table>
                </div>
            </div>

            <!-- Mensaje final -->
            <div class="alert alert-success text-center mt-4">
                <h5 class="mb-3">
                    <i class="fas fa-thumbs-up me-2"></i>
                    ¡Gracias por su compra!
                </h5>
                <p class="mb-0">Recuerde seguir las indicaciones médicas</p>
            </div>

            <!-- Botones -->
            <div class="text-center">
                <button onclick="window.print()" class="btn btn-primary me-2">
                    <i class="fas fa-print me-2"></i> Imprimir Ticket
                </button>
                <a href="{% url 'recetas_pendientes' %}" class="btn btn-success">
                    <i class="fas fa-home me-2"></i> Volver a Recetas Pendientes
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
